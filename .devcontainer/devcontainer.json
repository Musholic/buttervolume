{
    "name": "buttervolume",
    "image": "mcr.microsoft.com/devcontainers/python:3.13-trixie",
    "features": {
        "ghcr.io/jsburckhardt/devcontainer-features/uv:1": {}
    },
    "remoteUser": "root",
    "privileged": true,
    "containerEnv": {
        "SSH_PORT": "2222"
    },
    "remoteEnv": {
        "SSH_PORT": "2222"
    },
    "postCreateCommand": "./.devcontainer/post-create.sh",
    "postStartCommand": "./.devcontainer/post-start.sh"
}
